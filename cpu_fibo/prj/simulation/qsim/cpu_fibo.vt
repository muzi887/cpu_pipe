else
	$display ("Simulation passed !");
$finish;
end 
endmodule

module cpu_fibo_vlg_vec_tst();
// constants                                           
// general purpose registers
reg clk;
reg rst;
// wires                                               
wire [15:0] data_from_ram;
wire [15:0] debug_AC_reg;
wire [15:0] debug_AX_reg;
wire [2:0] debug_Bus_Sel;
wire [15:0] debug_BX_reg;
wire [15:0] debug_CX_reg;
wire [15:0] debug_internal_bus;
wire [15:0] debug_IR_reg;
wire debug_LoadPC;
wire [15:0] debug_MAR_reg;
wire [15:0] debug_MDR_reg;
wire [1:0] debug_MDR_Sel;
wire [15:0] debug_PC_next;
wire [15:0] debug_PC_reg;
wire [1:0] debug_PC_Sel;
wire debug_PSW_Z_flag_out;
wire [3:0] IR_opCode_out;
wire [31:0] microCommands;
wire [4:0] nextAddress;

wire sampler;                             

// assign statements (if any)                          
cpu_fibo i1 (
// port map - connection between master ports and signals/registers   
	.clk(clk),
	.data_from_ram(data_from_ram),
	.debug_AC_reg(debug_AC_reg),
	.debug_AX_reg(debug_AX_reg),
	.debug_Bus_Sel(debug_Bus_Sel),
	.debug_BX_reg(debug_BX_reg),
	.debug_CX_reg(debug_CX_reg),
	.debug_internal_bus(debug_internal_bus),
	.debug_IR_reg(debug_IR_reg),
	.debug_LoadPC(debug_LoadPC),
	.debug_MAR_reg(debug_MAR_reg),
	.debug_MDR_reg(debug_MDR_reg),
	.debug_MDR_Sel(debug_MDR_Sel),
	.debug_PC_next(debug_PC_next),
	.debug_PC_reg(debug_PC_reg),
	.debug_PC_Sel(debug_PC_Sel),
	.debug_PSW_Z_flag_out(debug_PSW_Z_flag_out),
	.IR_opCode_out(IR_opCode_out),
	.microCommands(microCommands),
	.nextAddress(nextAddress),
	.rst(rst)
);

// clk
initial
begin
	repeat(333)
	begin
		clk = 1'b0;
		clk = #1500 1'b1;
		# 1500;
	end
	clk = 1'b0;
end 

// rst
initial
begin
	rst = 1'b0;
	rst = #10000 1'b1;
end 

cpu_fibo_vlg_sample_tst tb_sample (
	.clk(clk),
	.rst(rst),
	.sampler_tx(sampler)
);

cpu_fibo_vlg_check_tst tb_out(
	.data_from_ram(data_from_ram),
	.debug_AC_reg(debug_AC_reg),
	.debug_AX_reg(debug_AX_reg),
	.debug_Bus_Sel(debug_Bus_Sel),
	.debug_BX_reg(debug_BX_reg),
	.debug_CX_reg(debug_CX_reg),
	.debug_internal_bus(debug_internal_bus),
	.debug_IR_reg(debug_IR_reg),
	.debug_LoadPC(debug_LoadPC),
	.debug_MAR_reg(debug_MAR_reg),
	.debug_MDR_reg(debug_MDR_reg),
	.debug_MDR_Sel(debug_MDR_Sel),
	.debug_PC_next(debug_PC_next),
	.debug_PC_reg(debug_PC_reg),
	.debug_PC_Sel(debug_PC_Sel),
	.debug_PSW_Z_flag_out(debug_PSW_Z_flag_out),
	.IR_opCode_out(IR_opCode_out),
	.microCommands(microCommands),
	.nextAddress(nextAddress),
	.sampler_rx(sampler)
);
endmodule

